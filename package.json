{
  "name": "kicklink",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run dev --workspace @kicklink/mobile",
    "dev:web": "npm run dev --workspace @kicklink/web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build:web": "npm run build --workspace @kicklink/web",
    "supabase:start": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:USERPROFILE=(Join-Path (Get-Location) '.local-home'); $env:HOME=$env:USERPROFILE; .\\node_modules\\.bin\\supabase start\"",
    "supabase:stop": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:USERPROFILE=(Join-Path (Get-Location) '.local-home'); $env:HOME=$env:USERPROFILE; .\\node_modules\\.bin\\supabase stop\"",
    "supabase:reset": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:USERPROFILE=(Join-Path (Get-Location) '.local-home'); $env:HOME=$env:USERPROFILE; .\\node_modules\\.bin\\supabase db reset\"",
    "db:types": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:USERPROFILE=(Join-Path (Get-Location) '.local-home'); $env:HOME=$env:USERPROFILE; $env:SUPABASE_ACCESS_TOKEN='local-placeholder'; .\\node_modules\\.bin\\supabase gen types typescript --local 2>$null | Set-Content -Encoding utf8 -LiteralPath apps/web/lib/database.types.ts\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.22",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "supabase": "^2.106.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
