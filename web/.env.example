# ── Database ──────────────────────────────────────────────────────
# Local dev runs Postgres in-container; prod points at managed Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kicklink?schema=public"

# ── Auth.js ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-me"
AUTH_TRUST_HOST=true
# Comma-separated emails that can access /admin/applications.
ADMIN_EMAILS="organizer@kicklink.app"
# Public base URL (used in verification / reset emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google sign-in (optional) ─────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com
# Authorized redirect URI: <APP_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Email (optional, for verification & password reset) ───────────
# Free key at https://resend.com — without it, links are logged to the server console.
RESEND_API_KEY=""
EMAIL_FROM="KickLink <onboarding@resend.dev>"

# ── Payments: Stripe Connect (optional) ───────────────────────────
# Without these, a local test payment flow is used so the app stays functional.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Optional platform fee (basis points, e.g. 500 = 5%) taken on each game payment.
PLATFORM_FEE_BPS="0"
