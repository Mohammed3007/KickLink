# Local defaults are printed by `npm run supabase:start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Leave blank unless a narrow, audited privileged operation truly needs it.
# Never expose this through a NEXT_PUBLIC_ variable.
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Configure Google in Supabase Auth providers. Do not expose client secrets to browser code.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Mobile is inactive during the web-first phase.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Stripe Connect will be introduced later behind the PaymentProvider boundary.
# Do not put Stripe secret keys in client apps.
